{
  "name": "RinexPrep Dev",
  "image": "mcr.microsoft.com/devcontainers/go:1.26-trixie",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-vscode.makefile-tools",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker",
        "streetsidesoftware.code-spell-checker",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.lintTool": "golangci-lint",
        "go.lintFlags": ["--fast"],
        "editor.formatOnSave": true,
        "[go]": {
          "editor.defaultFormatter": "golang.go"
        }
      }
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder}/.ssh,target=/home/vscode/.ssh-signing,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "COPILOT_HOME": "/workspaces/RinexPrep/.copilot"
  },
  "postCreateCommand": "command -v copilot >/dev/null 2>&1 || (curl -fsSL https://gh.io/copilot-install | bash) && go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest && go install github.com/air-verse/air@latest && go install gotest.tools/gotestsum@latest && go mod tidy || true && if [ -f /home/vscode/.ssh-signing/signing_key ]; then chmod 600 /home/vscode/.ssh-signing/signing_key; fi",
  "remoteUser": "vscode",
  "forwardPorts": [8080]
}
